---
interface Props {
  headline?: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  headline = 'Ready to build something that moves?',
  sub = "Whether you're launching a brand, scaling a campaign, or just need a team that gets it — we'd love to hear your brief.",
  ctaLabel = 'Send us a brief',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="cta-banner section noise">
  <div class="container cta-inner" data-stagger>
    <svg
      class="cta-line"
      viewBox="0 0 100 1"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <line x1="0" y1="0.5" x2="100" y2="0.5" />
    </svg>

    <h2 class="cta-head reveal">{headline}</h2>
    <p class="cta-sub reveal">{sub}</p>
    <a href={ctaHref} class="btn btn-primary cta-btn reveal">{ctaLabel}</a>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--dark-bg);
    color: var(--dark-text);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }

  .cta-line {
    width: 100%;
    height: 2px;
    margin-bottom: 24px;
    overflow: visible;
  }
  .cta-line line {
    stroke: var(--accent);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 1.4s var(--ease-out-expo);
  }
  .cta-line.draw line {
    stroke-dashoffset: 0;
  }

  .cta-head {
    font-family: var(--font-display);
    font-size: clamp(38px, 6vw, 72px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #fff;
    max-width: 20ch;
  }

  .cta-sub {
    font-size: clamp(16px, 2vw, 18px);
    line-height: 1.7;
    color: rgba(245, 245, 243, 0.8);
    max-width: 56ch;
  }

  .cta-btn {
    margin-top: 8px;
  }
</style>

<script>
  document.querySelectorAll<SVGElement>('.cta-line').forEach((line) => {
    if (!('IntersectionObserver' in window)) {
      line.classList.add('draw');
      return;
    }
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            line.classList.add('draw');
            obs.disconnect();
          }
        });
      },
      { threshold: 0.6 }
    );
    io.observe(line);
  });
</script>
