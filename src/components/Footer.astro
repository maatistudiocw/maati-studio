---
const year = new Date().getFullYear();
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img
        src="/images/Maati%20Logo_Bone.png"
        alt="Maati"
        height="40"
        class="footer-logo"
      />
      <p class="footer-tagline">People. Craft. Momentum.</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="footer-contact">
      <a href="mailto:hello@maati.studio">hello@maati.studio</a>
      <span>Bangalore, India</span>
    </div>
  </div>

  <div class="container footer-base">
    <p>&copy; {year} Maati. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark-bg);
    color: var(--dark-text);
    padding-block: 80px 40px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 48px;
    align-items: start;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(245, 245, 243, 0.12);
  }

  .footer-logo {
    height: 40px;
    width: auto;
    margin-bottom: 20px;
  }
  .footer-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--dark-text);
    opacity: 0.9;
  }

  .footer-links,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .footer-links a,
  .footer-contact a,
  .footer-contact span {
    font-size: 15px;
    color: rgba(245, 245, 243, 0.78);
    transition: color 0.2s ease;
  }
  .footer-links a:hover,
  .footer-contact a:hover {
    color: var(--accent-light);
  }

  .footer-base {
    padding-top: 32px;
  }
  .footer-base p {
    font-size: 13px;
    color: rgba(245, 245, 243, 0.5);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
