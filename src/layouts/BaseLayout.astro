---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Maati — Marketing & Creative Agency',
  description = 'Maati is a full-service marketing and creative agency based in Bangalore. Strategy to screen. Brand to brief. We make things move.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/Favicon.png" />
    <link rel="apple-touch-icon" href="/images/Favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta
      property="og:image"
      content="https://maati.studio/images/Default%20Image.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://maati.studio/images/Default%20Image.png"
    />

    <!-- Google Fonts: Inter + Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />

    <!-- Pre-paint gate: skip intro if seen this session; pre-cover overlay on internal nav -->
    <script is:inline>
      try {
        var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (rm || sessionStorage.getItem('maati-intro-seen') === 'true') {
          document.documentElement.dataset.introSeen = '1';
        }
        if (!rm && sessionStorage.getItem('maati-nav-transition')) {
          document.documentElement.dataset.navIn = '1';
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <!-- Logo intro / launch animation -->
    <div id="intro" aria-hidden="true">
      <img
        id="intro-logo"
        src="/images/Maati%20Logo_Maati%20Black.png"
        alt=""
      />
    </div>

    <!-- Page transition overlay -->
    <div class="page-transition" id="page-transition" aria-hidden="true"></div>

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Cursor follower -->
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>

    <!-- Earth/sand particle splash on click -->
    <canvas id="particle-canvas" aria-hidden="true"></canvas>

    <style>
      #intro {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-primary);
      }
      #intro-logo {
        width: 240px;
        height: auto;
        opacity: 0;
        will-change: opacity;
      }
      /* Hidden when the intro has already played this session */
      [data-intro-seen] #intro {
        display: none;
      }
      /* Content starts hidden only while the intro is actively playing */
      body.intro-playing main,
      body.intro-playing footer {
        opacity: 0;
      }

      /* Click particle canvas */
      #particle-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9998;
      }
    </style>

    <script>
      const reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      /* ------------------------------------------------------------------
         LOGO INTRO — scale up, then shrink + fly to the nav logo
      ------------------------------------------------------------------ */
      // Triggers the page entrance animations (nav + hero) exactly once.
      const enterPage = () => document.body.classList.add('page-entered');

      const setupIntro = () => {
        const intro = document.getElementById('intro');
        const logo = document.getElementById('intro-logo');
        const skip = document.documentElement.dataset.introSeen === '1';

        // No intro (already seen this session, or reduced motion):
        // reveal the page and play entrance animations immediately.
        if (!intro || !logo || skip) {
          if (intro) intro.style.display = 'none';
          enterPage();
          return;
        }

        document.body.classList.add('intro-playing');
        const main = document.querySelector('main');

        const finish = () => {
          intro.style.display = 'none';
          document.body.classList.remove('intro-playing');
          enterPage();
          try {
            sessionStorage.setItem('maati-intro-seen', 'true');
          } catch (e) {}
        };

        if (typeof logo.animate !== 'function') {
          finish();
          return;
        }

        // Fade in → hold → fade out → cover fades (no scaling, no movement)
        const fadeIn = logo.animate([{ opacity: 0 }, { opacity: 1 }], {
          duration: 800,
          easing: 'ease-out',
          fill: 'forwards',
        });

        fadeIn.finished
          .then(() => new Promise((res) => window.setTimeout(res, 1000)))
          .then(() => {
            const fadeOut = logo.animate([{ opacity: 1 }, { opacity: 0 }], {
              duration: 600,
              easing: 'ease-in',
              fill: 'forwards',
            });
            return fadeOut.finished;
          })
          .then(() => {
            intro.animate([{ opacity: 1 }, { opacity: 0 }], {
              duration: 500,
              easing: 'ease-in',
              fill: 'forwards',
            });
            if (main) {
              main.animate([{ opacity: 0 }, { opacity: 1 }], {
                duration: 500,
                easing: 'ease-out',
                fill: 'forwards',
              });
            }
            window.setTimeout(finish, 520);
          })
          .catch(finish);
      };

      /* ------------------------------------------------------------------
         GENERIC COUNT-UP — any [data-count-to] counts when in view
      ------------------------------------------------------------------ */
      const setupCounters = () => {
        const els =
          document.querySelectorAll<HTMLElement>('[data-count-to]');
        if (!els.length) return;

        const run = (el: HTMLElement) => {
          const target = Number(el.dataset.countTo || '0');
          const suffix = el.dataset.suffix || '';
          if (reduceMotion) {
            el.textContent = `${target}${suffix}`;
            return;
          }
          const duration = 2000;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = `${Math.round(target * eased)}${suffix}`;
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = `${target}${suffix}`;
          };
          requestAnimationFrame(tick);
        };

        if (!('IntersectionObserver' in window)) {
          els.forEach(run);
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                run(e.target as HTMLElement);
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.5 }
        );
        els.forEach((el) => io.observe(el));
      };

      /* ------------------------------------------------------------------
         1 + 3 — SCROLL REVEAL (0.08s child stagger)
      ------------------------------------------------------------------ */
      const setupReveal = () => {
        const els = document.querySelectorAll<HTMLElement>('.reveal');

        document
          .querySelectorAll<HTMLElement>('[data-stagger]')
          .forEach((group) => {
            const step = Number(group.dataset.stagger) || 0.08;
            group
              .querySelectorAll<HTMLElement>('.reveal')
              .forEach((child, i) => {
                child.style.transitionDelay = `${i * step}s`;
              });
          });

        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );

        els.forEach((el) => observer.observe(el));
      };

      /* ------------------------------------------------------------------
         CURSOR FOLLOWER (fine-pointer only)
      ------------------------------------------------------------------ */
      const setupCursor = () => {
        const dot = document.getElementById('cursor-dot');
        const fine = window.matchMedia('(hover: hover) and (pointer: fine)');
        if (!dot || reduceMotion || !fine.matches) return;

        document.body.classList.add('has-cursor');
        let x = window.innerWidth / 2;
        let y = window.innerHeight / 2;
        let cx = x;
        let cy = y;

        window.addEventListener(
          'mousemove',
          (e) => {
            x = e.clientX;
            y = e.clientY;
          },
          { passive: true }
        );

        const loop = () => {
          // 0.1s lag — exponential smoothing toward the pointer
          cx += (x - cx) * 0.18;
          cy += (y - cy) * 0.18;
          dot.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
          requestAnimationFrame(loop);
        };
        loop();

        const hoverSel = 'a, button, .interactive';
        document.querySelectorAll(hoverSel).forEach((el) => {
          el.addEventListener('mouseenter', () =>
            dot.classList.add('is-hover')
          );
          el.addEventListener('mouseleave', () =>
            dot.classList.remove('is-hover')
          );
        });
      };

      /* ------------------------------------------------------------------
         PAGE TRANSITION — olive wipe on internal navigation
      ------------------------------------------------------------------ */
      const setupPageTransition = () => {
        const overlay = document.getElementById('page-transition');
        if (!overlay) return;

        const arrivedViaNav =
          document.documentElement.dataset.navIn === '1' && !reduceMotion;

        try {
          sessionStorage.removeItem('maati-nav-transition');
        } catch (e) {}

        if (arrivedViaNav) {
          // Overlay is pre-covering (via [data-nav-in]); slide it out upward.
          requestAnimationFrame(() => {
            document.documentElement.removeAttribute('data-nav-in');
            overlay.classList.add('exit');
            window.setTimeout(() => overlay.classList.remove('exit'), 460);
          });
        } else {
          document.documentElement.removeAttribute('data-nav-in');
        }

        if (reduceMotion) return;

        document.querySelectorAll('a[href]').forEach((a) => {
          const link = a as HTMLAnchorElement;
          link.addEventListener('click', (e) => {
            const url = new URL(link.href, location.href);
            const internal =
              url.origin === location.origin &&
              !link.target &&
              !link.hasAttribute('download') &&
              url.pathname !== location.pathname;
            if (!internal || e.metaKey || e.ctrlKey || e.shiftKey) return;
            e.preventDefault();
            try {
              sessionStorage.setItem('maati-nav-transition', '1');
            } catch (er) {}
            overlay.classList.add('cover');
            window.setTimeout(() => {
              window.location.href = url.href;
            }, 420);
          });
        });
      };

      const init = () => {
        setupIntro();
        setupCounters();
        setupReveal();
        setupCursor();
        setupPageTransition();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

    <!-- Earth/sand click-splash particle system -->
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const canvas = document.getElementById(
          'particle-canvas'
        ) as HTMLCanvasElement | null;
        const ctx = canvas?.getContext('2d');

        if (canvas && ctx) {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
          window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
          });

          const COLORS = [
            '#7A8A3A', // olive
            '#2C3A12', // dark forest
            '#A8B86A', // pale olive
            '#1C1C1C', // charcoal
            '#8C7560', // warm grey-brown (subtle earth tone)
          ];

          class Particle {
            x: number;
            y: number;
            size: number;
            color: string;
            speedX: number;
            speedY: number;
            gravity: number;
            friction: number;
            opacity: number;
            decay: number;
            shape: 'circle' | 'blob';
            rotation: number;
            rotationSpeed: number;

            constructor(x: number, y: number) {
              this.x = x;
              this.y = y;
              this.size = Math.random() * 6 + 2; // 2–8px
              this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
              this.speedX = (Math.random() - 0.5) * 8; // spread left/right
              this.speedY = (Math.random() - 1.5) * 6; // burst upward
              this.gravity = 0.25;
              this.friction = 0.98;
              this.opacity = 1;
              this.decay = Math.random() * 0.02 + 0.015; // fade speed
              this.shape = Math.random() > 0.4 ? 'circle' : 'blob';
              this.rotation = Math.random() * Math.PI * 2;
              this.rotationSpeed = (Math.random() - 0.5) * 0.2;
            }
            update() {
              this.speedY += this.gravity;
              this.speedX *= this.friction;
              this.x += this.speedX;
              this.y += this.speedY;
              this.opacity -= this.decay;
              this.rotation += this.rotationSpeed;
            }
            draw() {
              ctx!.save();
              ctx!.globalAlpha = Math.max(0, this.opacity);
              ctx!.fillStyle = this.color;
              ctx!.translate(this.x, this.y);
              ctx!.rotate(this.rotation);
              if (this.shape === 'circle') {
                ctx!.beginPath();
                ctx!.arc(0, 0, this.size, 0, Math.PI * 2);
                ctx!.fill();
              } else {
                // irregular blob — slightly squished ellipse
                ctx!.beginPath();
                ctx!.ellipse(0, 0, this.size, this.size * 0.6, 0, 0, Math.PI * 2);
                ctx!.fill();
              }
              ctx!.restore();
            }
          }

          const particles: Particle[] = [];

          const spawnParticles = (x: number, y: number) => {
            const count = Math.floor(Math.random() * 10) + 12; // 12–22
            for (let i = 0; i < count; i++) {
              particles.push(new Particle(x, y));
            }
          };

          const animate = () => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for (let i = particles.length - 1; i >= 0; i--) {
              particles[i].update();
              particles[i].draw();
              if (particles[i].opacity <= 0) particles.splice(i, 1);
            }
            requestAnimationFrame(animate);
          };

          document.addEventListener('click', (e) => {
            spawnParticles(e.clientX, e.clientY);
          });

          animate();
        }
      }
    </script>
  </body>
</html>
