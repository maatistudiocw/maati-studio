---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBanner from '../components/CtaBanner.astro';

const principles = [
  {
    num: '01',
    title: 'Strategy First',
    body: 'Every brief starts with a question: what do you actually need? We resist the urge to jump to deliverables before we understand the problem.',
  },
  {
    num: '02',
    title: 'Craft at the Centre',
    body: "We don't rush execution. We sweat the details so you don't have to — because the difference between good and great lives in the details.",
  },
  {
    num: '03',
    title: 'Momentum as the Metric',
    body: 'We measure success by what moves — leads, conversations, culture. Visibility is a vanity number; momentum is the real one.',
  },
];

const models = [
  {
    title: 'Monthly Retainer',
    body: 'An ongoing partnership across disciplines, with a predictable scope and a dedicated team every month.',
  },
  {
    title: 'Project-based',
    body: 'A defined brief with a clear start and finish — a launch, a rebrand, a film, a website.',
  },
  {
    title: 'Agency of Record',
    body: 'We become your full creative and marketing department, owning the brand end to end.',
  },
  {
    title: 'Sprint Campaigns',
    body: 'Focused, fast-moving pushes built around a single moment — a launch, a season, an event.',
  },
  {
    title: 'Embedded Teams',
    body: 'Our specialists plug directly into your in-house team to add capacity and craft where you need it.',
  },
];
---

<BaseLayout
  title="About — Maati"
  description="Rooted in craft, built for impact. Maati is a full-stack marketing and creative agency in Bangalore serving brands, startups, and enterprises that want momentum."
>
  <Hero align="left" eyebrow="Who We Are">
    Rooted in craft.<br />Built for impact.
  </Hero>

  <!-- Brand story -->
  <section class="section bg-primary">
    <div class="container story reveal">
      <p class="story-copy">
        Maati — the Hindi word for earth, soil, the very material things are
        made from. We chose this name deliberately. Because great work isn't
        conjured from thin air. It's shaped, pressed, fired. It takes hands,
        time, and intention. We are a full-stack marketing and creative agency
        serving brands, startups, and enterprises that want momentum — not just
        visibility.
      </p>
    </div>
  </section>

  <!-- 3 Principles -->
  <section class="section bg-alt">
    <div class="container">
      <div class="section-intro reveal">
        <p class="eyebrow">What Guides Us</p>
        <h2 class="section-head">Three principles.</h2>
      </div>

      <div class="principles" data-stagger>
        {
          principles.map((p) => (
            <div class="principle reveal">
              <span class="principle-num">{p.num}</span>
              <div class="principle-text">
                <h3 class="principle-title">{p.title}</h3>
                <p class="principle-body">{p.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Engagement models -->
  <section class="section bg-primary">
    <div class="container">
      <div class="section-intro reveal">
        <p class="eyebrow">Ways to Work Together</p>
        <h2 class="section-head">How we engage</h2>
      </div>

      <div class="models" data-stagger>
        {
          models.map((m) => (
            <article class="model reveal">
              <h3 class="model-title">{m.title}</h3>
              <p class="model-body">{m.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>

<style>
  .story-copy {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.4vw, 36px);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    width: min(100%, 760px);
  }

  .section-intro {
    max-width: 60ch;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Principles — large numbered layout */
  .principles {
    display: flex;
    flex-direction: column;
  }
  .principle {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 40px;
    align-items: baseline;
    padding: 40px 0;
    border-top: 1px solid var(--text-subtle);
  }
  .principle:last-child {
    border-bottom: 1px solid var(--text-subtle);
  }
  .principle-num {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 80px);
    line-height: 1;
    color: var(--accent-light);
  }
  .principle-text {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .principle-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 34px);
    color: var(--text-primary);
  }
  .principle-body {
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 56ch;
  }

  /* Engagement models */
  .models {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .model {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 32px 28px 36px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .model:hover {
    transform: translateY(-4px);
    border-color: var(--accent-light);
  }
  .model-title {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .model-body {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .principle {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .models {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .models {
      grid-template-columns: 1fr;
    }
  }
</style>
