---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="Services — Maati"
  description="Every discipline, one direction. Brand strategy, design, motion, photography, social, digital marketing, web development, content, and integrated campaigns."
>
  <Hero
    align="left"
    eyebrow="Services"
    sub="From brand identity to performance campaigns, from a single photograph to a full brand film — we cover the full creative and marketing stack."
  >
    Every discipline.<br />One direction.
  </Hero>

  {
    services.map((s, i) => (
      <section class:list={['section', 'svc', i % 2 === 0 ? 'bg-alt' : 'bg-primary']}>
        <div class="container svc-inner" data-stagger>
          <div class="svc-head reveal">
            <span class="svc-num">{s.number}</span>
            <h2 class="svc-name">{s.name}</h2>
            <p class="svc-tagline">{s.tagline}</p>
          </div>
          <ul class="svc-list reveal">
            {s.subServices.map((sub) => (
              <li>{sub}</li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }

  <CtaBanner />
</BaseLayout>

<style>
  .svc-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .svc-head {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
  }
  .svc-num {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 88px);
    line-height: 1;
    color: var(--accent-light);
    letter-spacing: -0.02em;
  }
  .svc-name {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.08;
    color: var(--text-primary);
  }
  .svc-tagline {
    font-size: clamp(17px, 2vw, 19px);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 38ch;
  }

  .svc-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-top: 14px;
  }
  .svc-list li {
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-primary);
    padding: 16px 0 16px 26px;
    border-top: 1px solid var(--border);
    position: relative;
  }
  .svc-list li:last-child {
    border-bottom: 1px solid var(--border);
  }
  .svc-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.45em;
    width: 6px;
    height: 6px;
    background: var(--accent);
  }

  @media (max-width: 820px) {
    .svc-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
